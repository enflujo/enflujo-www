{
  "name": "enflujo-www",
  "packageManager": "yarn@4.13.0",
  "version": "1.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 3000",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "revisar": "astro check",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write --list-different .",
    "serve": "yarn server:start",
    "stop": "yarn server:stop",
    "restart": "yarn server:restart",
    "server:start": "yarn build && pm2 start ecosystem.config.js",
    "server:stop": "pm2 stop ecosystem.config.js",
    "server:restart": "pm2 restart ecosystem.config.js"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "3.7.2",
    "@enflujo/alquimia": "^2.0.0",
    "@rollup/plugin-graphql": "^2.0.5",
    "@speed-highlight/core": "^1.2.15",
    "astro": "5.18.1",
    "astro-robots-txt": "^1.0.0",
    "astro-seo-schema": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "marked": "^17.0.6",
    "marked-highlight": "^2.2.4",
    "schema-dts": "^1.1.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "graphql": "^16.13.2",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.99.0"
  }
}
